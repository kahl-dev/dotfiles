#!/usr/bin/env bash
# SSH Agent Keeper - Maintains SSH agent forwarding across connection changes.
# Only activates on remote servers (when SSH_CLIENT is set).
#
# Runs as a background daemon, delegating the actual scan-and-apply logic
# to bin/ssh-agent-find-socket (single source of truth, bounded by timeout 1
# on every ssh-add probe so a broken agent cannot hang the loop).

set -euo pipefail

# Only run on remote servers
if [[ -z "${SSH_CLIENT:-}" ]]; then
    exit 0
fi

LOG_FILE="$HOME/.ssh/ssh-agent-keeper.log"
PID_FILE="$HOME/.ssh/ssh-agent-keeper.pid"
FIND_SOCKET="$HOME/.dotfiles/bin/ssh-agent-find-socket"
POLL_INTERVAL=5

DEBUG=${SSH_AGENT_DEBUG:-0}
debug() {
    [[ $DEBUG -eq 1 ]] && echo "[SSH-AGENT-KEEPER] $*" | tee -a "$LOG_FILE" >&2
}

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
}

# Refuse to start if another keeper is already running.
if [[ -f "$PID_FILE" ]]; then
    old_pid=$(cat "$PID_FILE")
    if kill -0 "$old_pid" 2>/dev/null; then
        debug "SSH agent keeper already running (PID: $old_pid)"
        exit 0
    else
        debug "Removing stale PID file"
        rm -f "$PID_FILE"
    fi
fi

echo $$ > "$PID_FILE"

cleanup() {
    debug "Cleaning up SSH agent keeper"
    rm -f "$PID_FILE"
    exit 0
}
trap cleanup EXIT INT TERM

mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"

if [[ ! -x "$FIND_SOCKET" ]]; then
    log "ERROR: helper not found or not executable: $FIND_SOCKET"
    exit 1
fi

log "Starting SSH agent keeper on $(hostname)"
debug "SSH_CLIENT: ${SSH_CLIENT:-}"
debug "SSH_AUTH_SOCK: ${SSH_AUTH_SOCK:-}"

# Main loop: delegate to the shared helper. The helper short-circuits when
# ~/.ssh/ssh_auth_sock already points to a responsive agent, so the steady-
# state cost here is a single bounded `ssh-add -l` probe every POLL_INTERVAL.
while true; do
    "$FIND_SOCKET" --quiet || debug "No working SSH agent in this cycle"
    sleep "$POLL_INTERVAL"
done
