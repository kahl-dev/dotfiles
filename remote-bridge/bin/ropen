#!/usr/bin/env bash

# Remote URL opener
# Opens URLs on local machine via Remote Bridge

set -euo pipefail

# shellcheck source=../lib/bridge-token.sh
source "$(dirname "$0")/../lib/bridge-token.sh"
# shellcheck source=../lib/bridge-endpoint.sh
source "$(dirname "$0")/../lib/bridge-endpoint.sh"

# Configuration
resolve_bridge_endpoint
BRIDGE_URL="${BRIDGE_BASE_URL}/browser"

# Help text
show_help() {
    cat << EOF
ropen - Open URLs on local machine via Remote Bridge

Usage:
    ropen <url>                      # Open single URL
    ropen <url1> <url2> ...         # Open multiple URLs
    echo "url" | ropen              # Pipe URL
    ropen --batch < urls.txt        # Read URLs from file

Options:
    --app <name>     Open in specific application
    --batch          Read URLs from stdin (one per line)
    -h, --help       Show this help message

Environment:
    REMOTE_BRIDGE_SOCKET  Override the Unix socket path (default:
                          ~/.ssh/remote-bridge.sock, non-Darwin only)
Examples:
    # Open website
    ropen "https://example.com"

    # Open in specific browser
    ropen --app "Google Chrome" "https://example.com"

    # Open multiple URLs
    ropen "https://github.com" "https://google.com"
    
    # From file
    cat bookmarks.txt | ropen --batch
EOF
}

# Parse arguments
APP=""
BATCH_MODE=false
URLS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --app)
            APP="$2"
            shift 2
            ;;
        --batch)
            BATCH_MODE=true
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        -*)
            echo "Unknown option: $1" >&2
            show_help
            exit 1
            ;;
        *)
            URLS+=("$1")
            shift
            ;;
    esac
done

# Send URL via Remote Bridge
send_url() {
    local url="$1"
    
    # Base64 encode URL
    local encoded_url
    encoded_url=$(printf '%s' "$url" | base64)
    
    # Build metadata
    local metadata
    metadata=$(jq -n \
        --arg host "$(hostname -s)" \
        --arg session "${TMUX_PANE:-$$}" \
        --arg user "$USER" \
        --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '$ARGS.named')
    
    # Build options
    local options="{}"
    [ -n "$APP" ] && options="{\"app\": \"$APP\"}"
    
    # Send request
    local response
    if ! response=$(bridge_curl -sS --connect-timeout 0.5 --max-time 5 -X POST "$BRIDGE_URL" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $TOKEN" \
        -d "$(jq -n \
            --arg data "$encoded_url" \
            --argjson metadata "$metadata" \
            --argjson options "$options" \
            '{data: $data, metadata: $metadata, options: $options}')" \
        2>&1); then
        echo "Failed to open $url: $response" >&2
        return 1
    fi

    if echo "$response" | jq -e '.error' >/dev/null 2>&1; then
        local error
        error=$(echo "$response" | jq -r '.error')
        echo "Error opening $url: $error" >&2
        return 1
    fi
    echo "Opened: $url"
}

# Collect URLs
if [ "$BATCH_MODE" = true ] || { [ ${#URLS[@]} -eq 0 ] && [ ! -t 0 ]; }; then
    # Read from stdin
    while IFS= read -r url; do
        [ -n "$url" ] && URLS+=("$url")
    done
fi

# Validate we have URLs
if [ ${#URLS[@]} -eq 0 ]; then
    echo "Error: No URLs provided" >&2
    show_help
    exit 1
fi

require_bridge_socket || exit 1
TOKEN="$(require_bridge_token)" || exit 1
require_bridge_reachable || exit 1

# Process URLs
failed=0
for url in "${URLS[@]}"; do
    if ! send_url "$url"; then
        failed=$((failed + 1))
    fi
done

# Exit with error if any failed
[ $failed -eq 0 ] || exit 1
