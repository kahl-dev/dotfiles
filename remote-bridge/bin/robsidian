#!/usr/bin/env bash

# Remote Obsidian CLI wrapper
# Local: execs obsidian directly. Remote: proxies through Remote Bridge.
# Supports --stdin and --content-file for safe content passing (no shell escaping issues).

set -euo pipefail

BRIDGE_PORT="${REMOTE_BRIDGE_PORT:-}"
BRIDGE_URL="http://localhost:${BRIDGE_PORT}/obsidian/exec"

show_help() {
    cat << EOF
robsidian - Obsidian CLI wrapper for local and remote use

Usage:
    robsidian <command> [args...]                    Run obsidian CLI command
    robsidian create path="X" --stdin < file.md      Create note from stdin
    robsidian create path="X" --content-file=F       Create note from file
    robsidian append path="X" --stdin < file.md      Append from stdin

Options:
    --stdin              Read content from stdin (replaces content= argument)
    --content-file=F     Read content from file F (replaces content= argument)
    -h, --help           Show this help message

Environment:
    REMOTE_BRIDGE_PORT    If set, proxy through Remote Bridge (default: local exec)

Content Modes:
    1. Inline:   robsidian create path="X" content="simple text"
    2. Stdin:    cat note.md | robsidian create path="X" --stdin
    3. File:     robsidian create path="X" --content-file=/path/to/note.md

    Modes 2 and 3 bypass shell argument handling, safely supporting
    backticks, \$variables, unicode (®™), and any special characters.

Examples:
    robsidian vault
    robsidian search query="daily notes" format=json
    robsidian create path="notes/test.md" content="Hello"
    cat research.md | robsidian create path="notes/research.md" --stdin
    robsidian append path="notes/log.md" --content-file=/tmp/entry.md
EOF
}

# Parse for help flags
case "${1:-}" in
    -h|--help)
        show_help
        exit 0
        ;;
    "")
        echo "Error: No command provided" >&2
        echo "" >&2
        show_help
        exit 1
        ;;
esac

# Ensure Obsidian is running (local mode only)
ensure_obsidian_running() {
    if pgrep -x Obsidian >/dev/null 2>&1; then
        return 0
    fi

    echo "Starting Obsidian..." >&2
    open -g -a Obsidian

    local attempts=0
    local max_attempts=30
    while [ $attempts -lt $max_attempts ]; do
        if obsidian version 2>/dev/null >/dev/null; then
            return 0
        fi
        sleep 1
        attempts=$((attempts + 1))
    done

    echo "Error: Obsidian failed to start within ${max_attempts}s" >&2
    return 1
}

# Ensure a vault is loaded (local mode only) — after a background launch
# Obsidian can sit on the vault picker; every unscoped CLI command then
# answers "Vault not found." on stdout with exit code 0. Targeting the vault
# with an explicit vault= selector loads it without user interaction.
ensure_vault_loaded() {
    if obsidian vault 2>/dev/null | grep -q $'^path\t'; then
        return 0
    fi

    local registry="$HOME/Library/Application Support/obsidian/obsidian.json"
    local vault_path vault_name
    vault_path=$(jq -r '(.vaults | to_entries | map(.value)) as $v
        | (($v | map(select(.open)) | first) // (if ($v | length) == 1 then $v[0] else null end))
        | .path // empty' "$registry" 2>/dev/null)

    if [ -z "$vault_path" ]; then
        echo "Error: No unambiguous vault in $registry — open the desired vault in Obsidian manually" >&2
        return 1
    fi
    vault_name=$(basename "$vault_path")

    echo "Loading vault ${vault_name}..." >&2
    obsidian "vault=${vault_name}" version >/dev/null 2>&1 || true

    if ! obsidian vault 2>/dev/null | grep -q $'^path\t'; then
        echo "Error: Could not load vault \"${vault_name}\" via Obsidian CLI — open it in Obsidian manually" >&2
        return 1
    fi
}

# Extract --stdin and --content-file from arguments
STDIN_MODE=false
CONTENT_FILE=""
FILTERED_ARGS=()

for arg in "$@"; do
    case "$arg" in
        --stdin)
            STDIN_MODE=true
            ;;
        --content-file=*)
            CONTENT_FILE="${arg#--content-file=}"
            ;;
        --content-file)
            echo "Error: --content-file requires =path (e.g., --content-file=/tmp/note.md)" >&2
            exit 1
            ;;
        *)
            FILTERED_ARGS+=("$arg")
            ;;
    esac
done

# Read content from stdin or file
STDIN_CONTENT=""
if [ "$STDIN_MODE" = true ]; then
    if [ -t 0 ]; then
        echo "Error: --stdin specified but no data piped" >&2
        exit 1
    fi
    STDIN_CONTENT=$(cat)
elif [ -n "$CONTENT_FILE" ]; then
    if [ ! -f "$CONTENT_FILE" ]; then
        echo "Error: Content file not found: $CONTENT_FILE" >&2
        exit 1
    fi
    STDIN_CONTENT=$(cat "$CONTENT_FILE")
fi

# Re-add --stdin for the remote payload only — the server needs it to
# detect stdin content. FILTERED_ARGS itself must stay clean: the local
# mode below execs it directly against the real obsidian CLI, which has
# no --stdin flag of its own.
COMMAND_ARGS=("${FILTERED_ARGS[@]}")
if [ "$STDIN_MODE" = true ] || [ -n "$CONTENT_FILE" ]; then
    COMMAND_ARGS+=("--stdin")
fi

# Build command from filtered args, preserving values with spaces
COMMAND=""
for arg in "${COMMAND_ARGS[@]}"; do
    if [[ "$arg" == *=* ]]; then
        # key=value arg — quote the value to preserve spaces
        # Escape embedded " in value to prevent premature quote closure
        KEY="${arg%%=*}"
        VALUE="${arg#*=}"
        VALUE="${VALUE//\"/\\\"}"
        COMMAND="${COMMAND:+$COMMAND }${KEY}=\"${VALUE}\""
    elif [[ "$arg" == *" "* ]]; then
        COMMAND="${COMMAND:+$COMMAND }\"${arg}\""
    else
        COMMAND="${COMMAND:+$COMMAND }${arg}"
    fi
done

# Remote mode: proxy through bridge (skip if running on macOS — local Obsidian is available)
if [ -n "$BRIDGE_PORT" ] && [ "$(uname)" != "Darwin" ]; then
    # Check if bridge is available
    if ! curl -sf --connect-timeout 0.5 --max-time 2 "http://localhost:${BRIDGE_PORT}/health" >/dev/null 2>&1; then
        echo "Error: Remote Bridge is not available on port $BRIDGE_PORT" >&2
        echo "Make sure:" >&2
        echo "1. Remote Bridge service is running on your local machine" >&2
        echo "2. SSH tunnel is active (RemoteForward $BRIDGE_PORT localhost:$BRIDGE_PORT)" >&2
        exit 1
    fi

    # Sourced here rather than at the top of the file — local mode (the
    # common case on macOS) execs obsidian directly and never needs a token.
    # shellcheck source=../lib/bridge-token.sh
    source "$(dirname "$0")/../lib/bridge-token.sh"

    TOKEN="$(require_bridge_token)" || exit 1

    # Base64 encode the command (no line wrapping for JSON safety)
    ENCODED_COMMAND=$(printf '%s' "$COMMAND" | base64 -w0 2>/dev/null || printf '%s' "$COMMAND" | base64)

    # Build metadata
    METADATA=$(jq -n \
        --arg host "$(hostname -s)" \
        --arg session "${TMUX_PANE:-$$}" \
        --arg user "$USER" \
        --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '$ARGS.named')

    # Build JSON payload — with or without stdin content
    if [ -n "$STDIN_CONTENT" ]; then
        ENCODED_STDIN=$(printf '%s' "$STDIN_CONTENT" | base64 -w0 2>/dev/null || printf '%s' "$STDIN_CONTENT" | base64)
        PAYLOAD=$(jq -n \
            --arg data "$ENCODED_COMMAND" \
            --arg stdin "$ENCODED_STDIN" \
            --argjson metadata "$METADATA" \
            '{data: $data, stdin: $stdin, metadata: $metadata}')
    else
        PAYLOAD=$(jq -n \
            --arg data "$ENCODED_COMMAND" \
            --argjson metadata "$METADATA" \
            '{data: $data, metadata: $metadata}')
    fi

    # Send request
    RESPONSE=$(curl -sS --connect-timeout 0.5 --max-time 5 -X POST "$BRIDGE_URL" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $TOKEN" \
        -d "$PAYLOAD" \
        -w '\n%{http_code}' \
        2>&1)

    CURL_EXIT=$?

    if [ $CURL_EXIT -ne 0 ]; then
        echo "Error: Failed to connect to Remote Bridge: $RESPONSE" >&2
        exit 1
    fi

    # A rate-limited (429) response body is plain text, not JSON — the
    # status code, not the body shape, decides success. Split off the
    # %{http_code} line curl appended and hard-fail on any non-2xx.
    HTTP_CODE=$(printf '%s' "$RESPONSE" | tail -n1)
    BODY=$(printf '%s' "$RESPONSE" | sed '$d')

    if [ "$HTTP_CODE" -lt 200 ] || [ "$HTTP_CODE" -ge 300 ]; then
        # `|| true` matters under set -o pipefail: jq exits non-zero when
        # $BODY isn't valid JSON (e.g. express-rate-limit's plain-text 429),
        # and an unguarded pipeline failure here would trip errexit and kill
        # the script before the "Error: ..." message below ever runs.
        ERROR=$(printf '%s' "$BODY" | jq -r '.error // empty' 2>/dev/null || true)
        [ -z "$ERROR" ] && ERROR="HTTP $HTTP_CODE: $BODY"
        echo "Error: $ERROR" >&2
        exit 1
    fi

    # Extract wrapped response
    STDOUT=$(echo "$BODY" | jq -r '.stdout // ""')
    STDERR=$(echo "$BODY" | jq -r '.stderr // ""')
    EXIT_CODE=$(echo "$BODY" | jq -r '.exitCode // 0')

    # Output stdout
    [ -n "$STDOUT" ] && echo -n "$STDOUT"

    # Output stderr to stderr (suppressing obsidian loader noise)
    if [ -n "$STDERR" ]; then
        FILTERED_STDERR=$(echo "$STDERR" | grep -v "^\[.*\] " 2>/dev/null || true)
        [ -n "$FILTERED_STDERR" ] && echo "$FILTERED_STDERR" >&2
    fi

    exit "$EXIT_CODE"
fi

# Local mode: ensure Obsidian is running with a loaded vault, then exec
ensure_obsidian_running
ensure_vault_loaded

if [ -n "$STDIN_CONTENT" ]; then
    # Write stdin content to temp file, inject as content= argument
    TMPFILE=$(mktemp)
    trap 'rm -f "$TMPFILE"' EXIT
    printf '%s' "$STDIN_CONTENT" > "$TMPFILE"
    exec obsidian "${FILTERED_ARGS[@]}" content="$(cat "$TMPFILE")" 2>/dev/null
else
    exec obsidian "${FILTERED_ARGS[@]}" 2>/dev/null
fi
