#!/usr/bin/env bash

# Remote clipboard tool
# Sends data to local clipboard via Remote Bridge

set -euo pipefail

# shellcheck source=../lib/bridge-token.sh
source "$(dirname "$0")/../lib/bridge-token.sh"

# Configuration
BRIDGE_PORT="${REMOTE_BRIDGE_PORT:-8377}"
BRIDGE_URL="http://localhost:${BRIDGE_PORT}/clipboard"

TOKEN="$(require_bridge_token)" || exit 1

# Help text
show_help() {
    cat << EOF
rclip - Send data to local clipboard via Remote Bridge

Usage:
    rclip "text to copy"             # Copy text directly
    echo "text" | rclip              # Pipe text to clipboard
    rclip < file.txt                 # Send file contents

Options:
    --type <type>    Content type (text, etc.)
    --tag <tag>      Add a tag to the clipboard entry
    --json           Input is already base64 encoded JSON
    -h, --help       Show this help message

Environment:
    REMOTE_BRIDGE_PORT    Port for Remote Bridge (default: 8377)

Examples:
    # Copy text directly
    rclip "Hello World"

    # Copy command output
    ls -la | rclip

    # Copy file contents
    rclip < ~/.ssh/id_rsa.pub

    # Copy with metadata
    rclip "important data" --tag work

If the Remote Bridge is unreachable: outside tmux in a real terminal, rclip
falls back to OSC52 itself. Inside tmux, tmux's own set-clipboard delivers
OSC52 natively instead, so rclip fails honestly rather than emitting escape
bytes into a copy-pipe. Text only - binary input is rejected.
EOF
}

# Parse arguments
CONTENT_TYPE="text"
TAG=""
JSON_MODE=false
ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --type)
            CONTENT_TYPE="$2"
            shift 2
            ;;
        --tag)
            TAG="$2"
            shift 2
            ;;
        --json)
            JSON_MODE=true
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        -*)
            echo "Unknown option: $1" >&2
            show_help
            exit 1
            ;;
        *)
            # Collect non-option arguments
            ARGS+=("$1")
            shift
            ;;
    esac
done

# Read input
if [ -t 0 ] && [ ${#ARGS[@]} -eq 0 ]; then
    echo "Error: No input provided. Pipe data to rclip or provide as arguments." >&2
    echo "Examples:" >&2
    echo "  echo 'Hello' | rclip" >&2
    echo "  rclip 'Hello World'" >&2
    exit 1
fi

if [ ${#ARGS[@]} -gt 0 ]; then
    # Join arguments with spaces. Argv strings cannot contain NUL bytes (C
    # string limitation), so arg-mode input needs no binary check.
    INPUT="${ARGS[*]}"
else
    # NUL-safe stdin capture via temp file: $(cat) silently strips embedded
    # NULs AND trailing newlines, corrupting binary-looking input and losing
    # exact byte content that a real clipboard payload may depend on.
    INPUT_FILE="$(mktemp)"
    trap 'rm -f "$INPUT_FILE"' EXIT
    cat > "$INPUT_FILE"

    original_size=$(wc -c < "$INPUT_FILE")
    stripped_size=$(tr -d '\0' < "$INPUT_FILE" | wc -c)
    if [ "$original_size" != "$stripped_size" ]; then
        echo "Error: binary input not supported (clipboard is text-only)" >&2
        exit 1
    fi
fi

# Input accessors: arg-mode keeps INPUT as a plain string, stdin-mode reads
# from INPUT_FILE so trailing newlines and exact bytes survive.
input_base64() {
    if [ -n "${INPUT_FILE:-}" ]; then
        base64 < "$INPUT_FILE" | tr -d '\n'
    else
        printf '%s' "$INPUT" | base64 | tr -d '\n'
    fi
}

input_raw() {
    if [ -n "${INPUT_FILE:-}" ]; then
        cat "$INPUT_FILE"
    else
        printf '%s' "$INPUT"
    fi
}

input_is_empty() {
    if [ -n "${INPUT_FILE:-}" ]; then
        [ ! -s "$INPUT_FILE" ]
    else
        [ -z "$INPUT" ]
    fi
}

# Check for empty input
if input_is_empty; then
    echo "Warning: Empty input - nothing to copy" >&2
    exit 0
fi

# Check if Remote Bridge is available
check_bridge() {
    curl -sf --connect-timeout 0.5 --max-time 2 "${BRIDGE_URL%/clipboard}/health" >/dev/null 2>&1
}

# Send via Remote Bridge. Any failure here is a real error (bridge answered
# the health check but then failed the actual send, or rejected it with
# 401/4xx/5xx) - callers must NOT fall back to OSC52 on failure, since that
# would silently mask a misconfiguration (e.g. a bad token) as success.
send_via_bridge() {
    local data
    if [ "$JSON_MODE" = false ]; then
        data=$(input_base64)
    else
        data=$(input_raw)
    fi

    local metadata
    metadata=$(jq -n \
        --arg host "$(hostname -s)" \
        --arg session "${TMUX_PANE:-$$}" \
        --arg user "$USER" \
        --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '$ARGS.named')

    local options="{\"type\": \"$CONTENT_TYPE\""
    [ -n "$TAG" ] && options="$options, \"tag\": \"$TAG\""
    options="$options}"

    local response
    if ! response=$(curl -sS --connect-timeout 0.5 --max-time 5 -X POST "$BRIDGE_URL" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $TOKEN" \
        -d "$(jq -n \
            --arg data "$data" \
            --argjson metadata "$metadata" \
            --argjson options "$options" \
            '{data: $data, metadata: $metadata, options: $options}')" \
        -w '\n%{http_code}' \
        2>&1); then
        echo "Error: Remote Bridge unreachable during send: $response" >&2
        return 1
    fi

    # A rate-limited (429) response body is plain text, not JSON — the status
    # code, not the body shape, decides success. Split off the %{http_code}
    # line curl appended and hard-fail on any non-2xx.
    local http_code body
    http_code=$(printf '%s' "$response" | tail -n1)
    body=$(printf '%s' "$response" | sed '$d')

    if [ "$http_code" -lt 200 ] || [ "$http_code" -ge 300 ]; then
        local error
        # `|| true` matters under set -o pipefail: jq exits non-zero when
        # $body isn't valid JSON (e.g. express-rate-limit's plain-text 429),
        # and an unguarded pipeline failure here would trip errexit and kill
        # the script before the "Error: ..." message below ever runs.
        error=$(printf '%s' "$body" | jq -r '.error // empty' 2>/dev/null || true)
        [ -z "$error" ] && error="HTTP $http_code: $body"
        echo "Error: $error" >&2
        return 1
    fi

    return 0
}

# Fallback to OSC52 - only called when interactive and NOT inside tmux (see
# main logic below). Guards against oversized payloads since terminals cap
# the OSC52 escape sequence length.
send_via_osc52() {
    local encoded
    encoded=$(input_base64)

    local encoded_size=${#encoded}
    if [ "$encoded_size" -gt 72000 ]; then
        echo "Error: input too large for OSC52 fallback (${encoded_size} bytes); start the Remote Bridge" >&2
        return 1
    fi

    # tmux never reaches this function — the sole caller only invokes it when
    # `${TMUX:-}` is unset (tmux.conf's set-clipboard on already delivers
    # OSC52 natively from the copy-pipe in that case).
    if [ "$TERM" = "screen" ]; then
        # screen
        printf "\033P\033]52;c;%s\007\033\\" "$encoded"
    else
        # regular terminal
        printf "\033]52;c;%s\007" "$encoded"
    fi

    echo "(sent via OSC52 — Remote Bridge unavailable)" >&2
    return 0
}

# Main logic
if check_bridge; then
    if send_via_bridge; then
        echo "✓ Clipboard updated"
        exit 0
    fi
    exit 1
fi

# Bridge unreachable. Only fall back to OSC52 when interactive and not inside
# tmux: inside tmux, set-clipboard on (tmux.conf) already delivers OSC52
# natively from the copy-pipe, so rclip must fail honestly instead of
# emitting escape bytes that would do nothing useful there. When stdout is
# not a tty (e.g. nvim's systemlist capture), OSC52 bytes have no
# destination either.
if [ -z "${TMUX:-}" ] && [ -t 1 ]; then
    send_via_osc52
    exit $?
fi

echo "Error: Remote Bridge unavailable" >&2
exit 1
