#!/usr/bin/env bash

# Remote time tracking data fetch
# Fetches JSONL time tracking data from Remote Bridge server

set -euo pipefail

# shellcheck source=../lib/bridge-token.sh
source "$(dirname "$0")/../lib/bridge-token.sh"
# shellcheck source=../lib/bridge-endpoint.sh
source "$(dirname "$0")/../lib/bridge-endpoint.sh"

resolve_bridge_endpoint
BRIDGE_URL="${BRIDGE_BASE_URL}/time-tracking"

require_bridge() {
    require_bridge_socket || exit 1
    TOKEN="$(require_bridge_token)" || exit 1
    require_bridge_reachable || exit 1
}

# Surface a server-reported error distinctly from a connection failure — a
# 400 for malformed --dates (validated server-side) otherwise looks
# identical to a dead bridge. Also covers a rate-limited (429) response,
# whose body is plain text, not JSON: the status code, not the body shape,
# decides success. Splits the trailing %{http_code} line curl appended and
# leaves the JSON body in RESPONSE_BODY for the caller. Calls `exit`
# directly (not `return`) because callers invoke it un-subshelled — wrapping
# it in $(...) would trap the exit in that subshell instead of ending the
# script.
check_response_error() {
    local response="$1"
    local http_code
    http_code=$(printf '%s' "$response" | tail -n1)
    RESPONSE_BODY=$(printf '%s' "$response" | sed '$d')

    if [ "$http_code" -lt 200 ] || [ "$http_code" -ge 300 ]; then
        local error
        # `|| true` matters under set -o pipefail: jq exits non-zero when
        # $RESPONSE_BODY isn't valid JSON (e.g. express-rate-limit's
        # plain-text 429), and check_response_error runs un-subshelled at
        # top level here (not inside an if-tested call) — an unguarded
        # pipeline failure would trip errexit and kill the script before
        # the "Error: ..." message below ever runs.
        error=$(printf '%s' "$RESPONSE_BODY" | jq -r '.error // empty' 2>/dev/null || true)
        [ -z "$error" ] && error="HTTP $http_code: $RESPONSE_BODY"
        echo "Error: $error" >&2
        exit 1
    fi
}

show_help() {
    cat << EOF
rtime - Fetch time tracking data from Remote Bridge

Usage:
    rtime fetch --dates 2026-03-25,2026-03-24   # Fetch specific dates
    rtime fetch --week                           # Fetch last 7 days
    rtime fetch --today                          # Fetch today
    rtime dates                                  # List available dates

Options:
    --dates <dates>  Comma-separated dates (YYYY-MM-DD)
    --week           Last 7 days
    --today          Today only
    --output <dir>   Save JSONL files to directory (default: stdout JSON)
    -h, --help       Show this help message

Environment:
    REMOTE_BRIDGE_SOCKET  Override the Unix socket path (default:
                          ~/.ssh/remote-bridge.sock, non-Darwin only)

Output:
    JSON with hostname and per-date JSONL content.
    With --output, writes individual YYYY-MM-DD.jsonl files to the directory.
EOF
}

fetch_dates() {
    local dates="$1"
    local output_dir="${2:-}"

    require_bridge

    response=$(bridge_curl -sS --connect-timeout 0.5 --max-time 5 -H "Authorization: Bearer $TOKEN" "${BRIDGE_URL}?dates=${dates}" -w '\n%{http_code}' 2>/dev/null) || {
        echo "Error: Cannot connect to Remote Bridge at ${BRIDGE_BASE_URL}" >&2
        exit 1
    }
    check_response_error "$response"
    response="$RESPONSE_BODY"

    if [ -n "$output_dir" ]; then
        mkdir -p "$output_dir"
        echo "$response" | jq -r '.dates | to_entries[] | select(.value != "") | "\(.key)\t\(.value)"' | while IFS=$'\t' read -r date content; do
            echo "$content" > "${output_dir}/${date}.jsonl"
            echo "  ${date}.jsonl ($(echo "$content" | wc -l | tr -d ' ') lines)" >&2
        done
        hostname=$(echo "$response" | jq -r '.hostname')
        echo "Fetched from: ${hostname}" >&2
    else
        echo "$response"
    fi
}

list_dates() {
    local response

    require_bridge

    response=$(bridge_curl -sS --connect-timeout 0.5 --max-time 5 -H "Authorization: Bearer $TOKEN" "${BRIDGE_URL}/dates" -w '\n%{http_code}' 2>/dev/null) || {
        echo "Error: Cannot connect to Remote Bridge at ${BRIDGE_BASE_URL}" >&2
        exit 1
    }
    check_response_error "$response"
    response="$RESPONSE_BODY"

    echo "$response"
}

generate_date_list() {
    local mode="$1"
    case "$mode" in
        today)
            date -u +%Y-%m-%d
            ;;
        week)
            for i in $(seq 0 6); do
                date -u -v-${i}d +%Y-%m-%d 2>/dev/null || date -u -d "-${i} days" +%Y-%m-%d
            done | paste -sd, -
            ;;
    esac
}

# Parse arguments
if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
    fetch)
        DATES=""
        OUTPUT_DIR=""
        while [ $# -gt 0 ]; do
            case "$1" in
                --dates) DATES="$2"; shift 2 ;;
                --week) DATES=$(generate_date_list week); shift ;;
                --today) DATES=$(generate_date_list today); shift ;;
                --output) OUTPUT_DIR="$2"; shift 2 ;;
                -h|--help) show_help; exit 0 ;;
                *) echo "Unknown option: $1" >&2; exit 1 ;;
            esac
        done
        [ -z "$DATES" ] && { echo "Error: specify --dates, --week, or --today" >&2; exit 1; }
        fetch_dates "$DATES" "$OUTPUT_DIR"
        ;;
    dates)
        list_dates
        ;;
    -h|--help)
        show_help
        ;;
    *)
        echo "Unknown command: $COMMAND (use 'fetch' or 'dates')" >&2
        exit 1
        ;;
esac
