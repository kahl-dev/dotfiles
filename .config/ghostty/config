# https://ghostty.org/docs

# fonts
font-size = 16
font-style = medium
bold-is-bright = true
theme = Catppuccin Mocha
font-family = "JetBrainsMono Nerd Font Mono"

# cursor
cursor-style = block
cursor-style-blink = false


# clipboard
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
clipboard-read = allow
clipboard-write = allow

# mouse
mouse-scroll-multiplier = 2
mouse-hide-while-typing = true

# memory
scrollback-limit = 5000

# window
initial-window = true
resize-overlay = never
background-opacity = 0.85
window-save-state = always
window-step-resize = false
background-blur-radius = 15
window-padding-balance = true
confirm-close-surface = always

# behavior
auto-update = check
auto-update-channel = stable
quit-after-last-window-closed = true
shell-integration-features = no-cursor
scrollbar = never
scroll-to-bottom = output

# command finish notifications (unfocused = only when Ghostty not focused)
notify-on-command-finish = unfocused
notify-on-command-finish-after = 5s

# macos
macos-option-as-alt = false
macos-titlebar-style = hidden

keybind = global:super+alt+shift+ctrl+o=toggle_quick_terminal

# Remap Ctrl+T to send Alt+T (ESC+t) for Claude Code thinking toggle
# Allows Option key to remain free for umlauts (ä, ö, ü)
keybind = ctrl+t=esc:t

# Ghostty-native window management via leader key (Ctrl+G)
# Avoids tmux conflicts (Ctrl+B). Status indicator shows active key table.
# Press Ctrl+G, then action key. Escape or unknown key cancels.
keybind = ctrl+g=activate_key_table:ghostty
keybind = ghostty/escape=deactivate_key_table
keybind = ghostty/catch_all=deactivate_key_table

# ghostty: splits
keybind = ghostty/d=new_split:right
keybind = ghostty/shift+d=new_split:down
keybind = ghostty/enter=toggle_split_zoom
keybind = ghostty/left=goto_split:left
keybind = ghostty/right=goto_split:right
keybind = ghostty/up=goto_split:up
keybind = ghostty/down=goto_split:down
keybind = ghostty/equal=equalize_splits

# ghostty: surface
keybind = ghostty/w=close_surface

# ghostty: window
keybind = ghostty/f=toggle_fullscreen

