# https://ghostty.org/docs

# fonts
font-size = 12
font-style = medium
bold-is-bright = true
theme = Catppuccin Mocha
font-family = "JetBrainsMono Nerd Font Mono"

# cursor
cursor-style = block
cursor-style-blink = false


# clipboard
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
clipboard-read = allow
clipboard-write = allow

# mouse
mouse-scroll-multiplier = 2
mouse-hide-while-typing = true

# memory
scrollback-limit = 5000

# window
initial-window = true
resize-overlay = never
background-opacity = 0.85
window-save-state = always
window-step-resize = false
background-blur-radius = 15
window-padding-balance = true
confirm-close-surface = always

# behavior
auto-update = check
auto-update-channel = stable
quit-after-last-window-closed = true
shell-integration-features = no-cursor
scrollbar = never
scroll-to-bottom = output

# command finish notifications (unfocused = only when Ghostty not focused)
notify-on-command-finish = unfocused
notify-on-command-finish-after = 5s

# macos
# Right Option = Alt, so TUIs reach their Alt bindings (Claude Code Alt+T/O/P,
# opencode's Alt layer). Left Option keeps composing special characters — Option+u
# dead keys today, `{ } [ ] @ | ~` on a German layout later — so those are typed
# the same way inside the terminal as in any GUI app.
macos-option-as-alt = right
macos-titlebar-style = hidden

keybind = global:super+alt+shift+ctrl+o=toggle_quick_terminal

# config (defaults made explicit for discoverability)
keybind = super+shift+,=reload_config
keybind = super+,=open_config

# command palette — fuzzy-searchable list of every action + its keybind
# (Ghostty's closest equivalent to Neovim's which-key)
keybind = super+shift+p=toggle_command_palette

# Font zoom — Cmd: focused surface only · Cmd+Shift: every surface (all:)
# Bind both `plus`/`equal` so it works on US (=) and German (+) layouts.
keybind = super+plus=increase_font_size:1
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+0=reset_font_size

keybind = all:super+shift+plus=increase_font_size:1
keybind = all:super+shift+equal=increase_font_size:1
keybind = all:super+shift+minus=decrease_font_size:1
keybind = all:super+shift+0=reset_font_size

# Window management deliberately has no bindings here: Ghostty's own Cmd defaults
# already cover splits, zoom, navigation, equalize, close and fullscreen. Ctrl
# belongs to the TUIs — a leader key here cost nvim, Claude Code and opencode
# their Ctrl+G for actions that were already bound.
# Look them up rather than trusting a copy: `ghostty +list-keybinds --default`,
# or Cmd+Shift+P for the searchable palette. See docs/keybindings.md.

