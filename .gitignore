tmux/plugins/*
tmux/resurrect
!tmux/plugins/tpm
npm-debug.log
!.gitkeep
vscode/extensions/*

# Vim
vim/sessions/*
vim/tmp/*
vim/view/*

# Coc
vim/coc/*

brew/Basebrew.lock.json

tmux/plugins

nvim/undodir

# Allow bin/ by default - track our custom scripts
!bin/

# Exclude generated/installed content only
bin/fnm/
bin/git-lia/

!.config/bat/themes/*

# Claude Code sensitive data
.claude.global/projects/
.claude.global/todos/
.claude.global/statsig/

# Allow Claude configuration
!.claude.global/CLAUDE.md
!.claude.global/settings.json

logs

# Hammerspoon private configuration
.hammerspoon/config/private.json
# Hammerspoon device config (display UUIDs, Home Assistant) — lives in dotfiles-private
.hammerspoon/config/devices.json

# Audio manager device config (BT MAC addresses) — lives in dotfiles-private
.config/audio-manager/config.json

# Hammerspoon generated LSP stubs
.hammerspoon/Spoons/EmmyLua.spoon/

# Karabiner backup files (temporary + auto-generated)
.config/karabiner/karabiner.json.backup*
.config/karabiner/automatic_backups/

# RTK runtime artifacts
.config/rtk/.hook_warn_last
.config/rtk/tee/

# Yazi installed plugins (managed by ya pkg)
.config/yazi/plugins/

# Per-machine profile lock (written by install-profile on success)
.dotbot-profile
